# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here

# ── Google Sheets ──────────────────────────────────────────────────────────────
SPREADSHEET_ID=your_google_spreadsheet_id_here

# Path to your service-account JSON file (or paste the JSON as a string)
GOOGLE_CREDS_JSON=credentials.json

# ── Your Telegram user/chat ID (get it from @userinfobot) ─────────────────────
ADMIN_CHAT_ID=123456789

# Your Render Web Service URL (after first deploy, copy from Render dashboard)
# Example: https://lifeos-bot.onrender.com
WEBHOOK_URL=https://your-service-name.onrender.com
